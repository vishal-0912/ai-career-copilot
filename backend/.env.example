SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ANTHROPIC_API_KEY=your-anthropic-key
VOYAGE_API_KEY=your-voyage-key
VOYAGE_MIN_INTERVAL_MS=100
# ^ 21000 = ~3 RPM, for accounts with NO payment method on file.
# Added a card? Voyage's Tier 1 (any payment method on file) allows 2000 RPM —
# drop this to something like 100 (still leaves a safety margin, ~600 RPM effective).
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=in
PORT=4000
RAPIDAPI_JSEARCH_KEY=your-rapidapi-jsearch-key
JSEARCH_COUNTRY=in
